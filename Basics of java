## Secound Largest Number inb Arrays
2.import java.util.Arrays;
class Solution {
    public int getSecondLargest(int[] arr) {
        if (arr == null || arr.length < 2) {
            return -1; 
        }
        Arrays.sort(arr); 
        int largest = arr[arr.length - 1];
        for (int i = arr.length - 2; i >= 0; i--) {
            if (arr[i] != largest) {
                return arr[i];
            }
        }
        return -1; 
    }
}
